
echo "=== Running Pre-Push Quality Gate ==="

echo "[1/6] Running Pint..."
./vendor/bin/pint --test

echo "[2/6] Running PHPCS..."
./vendor/bin/phpcs

echo "[3/6] Running PHPStan..."
./vendor/bin/phpstan analyse --memory-limit=2G app bootstrap config database routes tests

echo "[4/6] Running PHPMD..."
./vendor/bin/phpmd app,config,database,routes text phpmd.xml

echo "[5/6] Checking for Pest Usage..."
./scripts/detect-pest.sh

echo "[6/6] Running PHPUnit with Coverage >= 90%..."
if [ ! -f public/build/manifest.json ]; then
  echo "Vite manifest not found. Building frontend assets..."
  npm run build
fi
./vendor/bin/phpunit --coverage-clover coverage.xml

echo "✅ Pre-Push Quality Gate Passed (Zero-Issue Policy Verified)"
