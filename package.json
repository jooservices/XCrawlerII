{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "lint": "eslint . --ext .js,.mjs,.cjs,.ts,.tsx --max-warnings=0",
        "precommit": "lint-staged",
        "prepare": "husky",
        "test": "vitest run --passWithNoTests"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.4.2",
        "@commitlint/config-conventional": "^20.4.2",
        "@eslint/js": "^9.37.0",
        "@inertiajs/vue3": "^2.0.0",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-vue": "^6.0.1",
        "@vue/test-utils": "^2.4.6",
        "autoprefixer": "^10.4.12",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "eslint": "^9.37.0",
        "husky": "^9.1.7",
        "laravel-vite-plugin": "^2.0.0",
        "lint-staged": "^16.2.7",
        "playwright": "^1.58.2",
        "postcss": "^8.4.31",
        "prettier": "^3.6.2",
        "tailwindcss": "^3.2.1",
        "vite": "^7.0.7",
        "vitest": "^4.0.18",
        "vue": "^3.4.0"
    },
    "dependencies": {
        "@fortawesome/fontawesome-svg-core": "^7.2.0",
        "@fortawesome/free-solid-svg-icons": "^7.2.0",
        "@fortawesome/vue-fontawesome": "^3.1.3",
        "@primevue/themes": "^4.5.4",
        "primeicons": "^7.0.0",
        "primevue": "^4.5.4"
    },
    "lint-staged": {
        "*.{js,mjs,cjs,ts,tsx}": [
            "eslint --cache --fix",
            "prettier --write"
        ],
        "*.{vue,json,md,css,scss,html,yml,yaml}": [
            "prettier --write"
        ]
    },
    "volta": {
        "node": "20.11.1",
        "npm": "10.2.4"
    }
}
