#!/usr/bin/env bash

# commit-msg hook
# Enforces Rule 12-GAT-005: Conventional Commits format (type(scope): description)

commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Allowed types (standard Angular/Conventional Commits types)
types="feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert"

# Regex for Conventional Commits
# Matches: type(scope): description OR type: description
regex="^(${types})(\([a-zA-Z0-9_\-]+\))?: [a-zA-Z0-9_\-\.\ ]+"

if ! echo "$commit_msg" | grep -i -E -q "$regex"; then
    echo -e "${RED}❌ Error [12-GAT-005]: Commit Message Lint Gate${NC}"
    echo -e "   Commit message does not follow Conventional Commits format."
    echo -e "   ${YELLOW}Required format:${NC} type(scope): description"
    echo -e "   ${YELLOW}Example:${NC} feat(auth): add login endpoint"
    echo -e "   ${YELLOW}Allowed types:${NC} feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
    echo -e ""
    echo -e "   ${RED}Your commit message:${NC} $commit_msg"
    exit 1
fi

exit 0
